{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["agent/**/*.ts", "evals/**/*.ts", "test/**/*.ts", "scripts/**/*.ts", "packages/*/src/**/*.ts", "packages/*/test/**/*.ts"],
  "exclude": ["packages/vespers/**"]
}
