# @agentic-research/dpop is notme's DPoP verifier SDK (canonical-hours-f49482
# ActionGate). It lives on GitHub Packages, NOT npmjs.org, and that registry
# requires authentication to install even for PUBLIC packages — 401 anonymous.
# Both lines below are required; the token is read from the environment so
# nothing secret is committed.
#
#   local dev:  gh auth refresh -h github.com -s read:packages
#               export NODE_AUTH_TOKEN=$(gh auth token)
#   CI:         NODE_AUTH_TOKEN=${{ secrets.GITHUB_TOKEN }} + `packages: read`
#
# `pnpm install` failing with ERR_PNPM_FETCH_401 means NODE_AUTH_TOKEN is unset
# or its token lacks the read:packages scope. See notme-18450e.
@agentic-research:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
