LECTIO_URL=            # streamable-HTTP MCP endpoint of the lectio daemon (tunnel is the user's problem)
LECTIO_TOKEN=          # lectio shared-secret token
GITHUB_TOKEN=          # read-scoped GitHub PAT (write-scoped too, if you set MCP_ACTION_TOKEN below)
ANTHROPIC_API_KEY=     # direct Anthropic provider (no AI Gateway)
# Optional:
# BOARD_DIR=board
# SANDBOX_BACKEND=auto   # auto | docker | vercel
# QUIET_HOURS=           # e.g. 22-07 — suppress overnight ticks
# QUIET_TZ=UTC

# Optional: enables the weather snapshot source when [weather] is set in canonical-hours.toml
WEATHER_API_KEY=

# Optional: enables the Linear source when [linear] is set in canonical-hours.toml
LINEAR_API_KEY=

# Optional but recommended: default-deny gate for the two mutating MCP action
# tools (resolve_addressed_review_threads, dismiss_stale_bot_reviews) —
# canonical-hours-49ba33. Unset means every call to either tool is denied.
# Callers must send `Authorization: Bearer <this value>`.
MCP_ACTION_TOKEN=

# Optional: absolute path to a built jamestexas/canonical-hours-private
# dist/index.js (canonical-hours-dfb779) — sensitive personal sources kept
# out of this public repo. Unset means the feature is simply off.
CANONICAL_HOURS_PRIVATE_SOURCES_PATH=
